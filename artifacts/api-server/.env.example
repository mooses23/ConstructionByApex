# ============================================================
# API Server — Environment Variables (Vercel)
# Set these in your Vercel project under Settings → Environment Variables.
# ============================================================

# PostgreSQL connection string from Supabase.
# Found in: Supabase Dashboard → Settings → Database → URI
# Append ?sslmode=require if not already present.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Set to "production" in Vercel. This enables SSL and cross-site cookies.
NODE_ENV=production

# Your frontend Vercel URL (required for cookies to work cross-origin).
# Example: https://your-frontend.vercel.app
# For multiple origins, comma-separate: https://site1.com,https://site2.com
CORS_ORIGIN=https://your-frontend-domain.vercel.app
