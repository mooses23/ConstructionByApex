# ============================================================
# API Server — Environment Variables
# Copy this file to .env and fill in your values.
# Set these in your Vercel project under Settings → Environment Variables.
# ============================================================

# PostgreSQL connection string from Supabase.
# Found in: Supabase Dashboard → Settings → Database → URI
# Append ?sslmode=require if not already present.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Set to "production" in Vercel. This enables SSL for the database connection.
NODE_ENV=production
