# ============================================================
# Frontend (Construction By Apex) — Environment Variables
# Copy this file to .env.local and fill in your values.
# Set these in your Vercel project under Settings → Environment Variables.
# ============================================================

# The full URL of your deployed API server on Vercel.
# Example: https://apex-api.vercel.app
# Leave empty if the frontend and API share the same origin.
VITE_API_URL=https://your-api-project.vercel.app

# Set automatically by Replit. Leave blank for Vercel (defaults to "/").
# BASE_PATH=/

# Set automatically by Replit. Leave blank for Vercel (defaults to 3000).
# PORT=3000
